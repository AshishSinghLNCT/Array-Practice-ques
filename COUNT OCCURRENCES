int count(int[] arr, int x) {
    return upper(arr, x) - lower(arr, x);
}

int lower(int[] arr, int x) {
    int l = 0, r = arr.length;
    while (l < r) {
        int m = (l + r) / 2;
        if (arr[m] < x) l = m + 1;
        else r = m;
    }
    return l;
}

int upper(int[] arr, int x) {
    int l = 0, r = arr.length;
    while (l < r) {
        int m = (l + r) / 2;
        if (arr[m] <= x) l = m + 1;
        else r = m;
    }
    return l;
}
